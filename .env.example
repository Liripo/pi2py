# Copy this file to .env and fill in real secrets. .env is ignored by git.

# DeepSeek
DEEPSEEK_API_KEY=

# OpenAI official API
OPENAI_API_KEY=

# OpenAI-compatible base URL. LiteLLM commonly reads OPENAI_API_BASE.
# Examples:
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_BASE=https://your-openai-compatible-endpoint/v1
OPENAI_API_BASE=

# Examples:
# uv run pi2py --model deepseek/deepseek-v4-flash -p "hello"
# uv run pi2py --model openai/gpt-4o-mini -p "hello"
